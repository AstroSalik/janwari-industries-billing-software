{
  "name": "janwari-industries-billing-software",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "start": "electron electron/main.js",
    "prepare:runtime-config": "node scripts/prepare-runtime-config.cjs",
    "build:client": "npm run build --prefix client",
    "build:server": "npm run db:generate --prefix server && npm run build --prefix server",
    "build": "npm run prepare:runtime-config && npm run build:client && npm run build:server",
    "package": "npm run build && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.janwari.industries.billing",
    "productName": "Janwari Industries Billing",
    "copyright": "Copyright © 2026 Janwari Industries",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "client/dist/**/*",
      "server/dist/**/*",
      "server/node_modules/**/*",
      "server/node_modules/.prisma/**/*",
      "server/package.json",
      "shared/**/*",
      "node_modules/**/*",
      "node_modules/.prisma/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true,
    "asarUnpack": [
      "server/node_modules/**/*",
      "server/node_modules/.prisma/**/*",
      "node_modules/.prisma/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/.prisma",
        "to": "app/node_modules/.prisma"
      },
      {
        "from": "server/node_modules/.prisma",
        "to": "app/server/node_modules/.prisma"
      }
    ]
  },
  "keywords": [],
  "author": "Janwari Industries",
  "license": "ISC",
  "description": "Janwari Industries Billing Software desktop client with hosted-backend support",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.4"
  }
}
